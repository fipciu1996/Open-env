# OpenClaw runtime and secrets for Operations Agent
# Use with: docker compose --env-file .operations-agent.env -f docker-compose-operations-agent.yml up -d

# OpenClaw runtime overrides
# docker compose builds and tags this image from the adjacent Dockerfile
OPENCLAW_IMAGE=openclawenv/ops-agent:1.2.3
OPENCLAW_CONFIG_DIR=./.openclaw
OPENCLAW_WORKSPACE_DIR=./workspace
OPENCLAW_GATEWAY_HOST_BIND=127.0.0.1
OPENCLAW_BRIDGE_HOST_BIND=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TMPFS=/tmp:rw,noexec,nosuid,nodev,size=64m
OPENCLAW_PIDS_LIMIT=256
OPENCLAW_NOFILE_SOFT=1024
OPENCLAW_NOFILE_HARD=2048
OPENCLAW_NPROC=512
OPENCLAW_TZ=UTC
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Bot secret references

# source: env:OPENAI_API_KEY
# required: true
OPENAI_API_KEY=
